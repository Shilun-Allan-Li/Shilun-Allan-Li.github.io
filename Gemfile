source 'https://rubygems.org'

# All theme files are vendored locally (from LazyRen/hydejack-pro base).
# No jekyll-theme-hydejack gem needed.
#
# Run with:
#   bundle exec jekyll serve

group :jekyll_plugins do
  gem 'github-pages'
  gem 'jekyll-include-cache'
  gem 'jekyll-compose'
  gem 'jekyll-sitemap'
end

gem 'wdm' if Gem.win_platform?
gem 'tzinfo-data' if Gem.win_platform?
gem "webrick", "~> 1.7"
